{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/pool-api/:path*", "destination": "https://p2.pearlerpool.com/:path*" },
    { "source": "/net-api/:path*", "destination": "https://pearltrack.io/api/:path*" },
    { "source": "/assets/:path*", "destination": "/:path*" }
  ]
}
